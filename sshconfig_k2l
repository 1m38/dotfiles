ServerAliveCountMax 10

Host *
     ForwardAgent yes

Host lotus
     Hostname lotus.kuee.kyoto-u.ac.jp
     User uno
     IdentityFile ~/.ssh/k2l_local.id_rsa

Host lotus/*
     User uno
     ProxyCommand ssh -W "$(basename "%h")":%p "$(dirname "%h")"

