# 60秒ごとに生存確認、10回失敗で切断
ServerAliveInterval 60
ServerAliveCountMax 10

Host *
     ForwardAgent yes

Host lotus
     Hostname lotus.kuee.kyoto-u.ac.jp
     User uno
     IdentityFile ~/.ssh/k2l_local.id_ecdsa

Host lotus/*
     User uno
     ProxyCommand ssh -W "$(basename "%h")":%p "$(dirname "%h")"

